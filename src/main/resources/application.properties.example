# =============================================
# stu-manage — Application Configuration
# =============================================
# HOW TO USE:
# 1. Copy this file
# 2. Rename the copy to application.properties
# 3. Fill in your own PostgreSQL DB credentials
# 4. Never share your application.properties!
# =============================================

spring.application.name=stu-manage-cloud

# =============================================
# PostgreSQL Database Connection
# =============================================
spring.datasource.url=${DATABASE_URL}
spring.datasource.username=${DATABASE_USERNAME}
spring.datasource.password=${DATABASE_PASSWORD}
spring.datasource.driver-class-name=org.postgresql.Driver

# =============================================
# JPA / Hibernate Settings
# =============================================
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true